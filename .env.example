# AkashiMedia — Фаза 1 MVP. Copy to .env and fill in. Never commit .env.

# --- Single shared login for the marketing team (Scope Cut: единый логин/пароль) ---
APP_USERNAME=marketing
APP_PASSWORD=change-me

# Session cookie signing key (>= 32 chars). Generate: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-me-to-a-long-random-hex-string

# Set to true when served behind TLS — adds the Secure flag to the session cookie.
APP_HTTPS_ONLY=false

# Used by Docker Compose for the local PostgreSQL data volume. Change for any
# shared/non-local deployment.
POSTGRES_PASSWORD=akashimedia_dev

# --- External APIs ---
OPENAI_API_KEY=sk-...
# Groq-hosted OpenAI-compatible model requested for the digest PoC.
OPENAI_MODEL=openai/gpt-oss-120b
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# --- Telegram data-center digest (standalone aiogram process) ---
TELEGRAM_BOT_TOKEN=
# Numeric channel id such as -100123..., or public channel username @channel.
TELEGRAM_CHANNEL_ID=
# Private chat allowed to trigger publication. Start the bot and send /start
# once to learn the numeric id, then set it here and restart.
TELEGRAM_CONTROL_CHAT_ID=
TAVILY_API_KEY=
# Number of industry-news posts per manual run (allowed: 1..5). One additional
# latest relevant Equinix Blog article is published after them.
DIGEST_POST_LIMIT=2
# Postgres connection is supplied automatically by Docker Compose. Set this
# when running the bot/worker directly outside containers.
DATABASE_URL=postgresql+psycopg://akashimedia:akashimedia_dev@localhost:5432/akashimedia

# Instagram Graph API token (S2) — leave blank to run with the fake publisher
IG_TOKEN=
# Instagram Business account id (Graph API target)
IG_USER_ID=
# Public HTTPS base of this app — required for Instagram Graph and Buffer image
# posts. The API fetches <PUBLIC_BASE_URL>/media/<token>. In dev use a tunnel,
# e.g. `cloudflared tunnel --url http://localhost:8000`.
PUBLIC_BASE_URL=

# LinkedIn API token (S3) — leave blank to run with the fake publisher
LI_TOKEN=
# LinkedIn member/author URN, e.g. urn:li:person:xxxx
LI_AUTHOR_URN=

# Optional: preferred Instagram/LinkedIn route through Buffer. Each configured
# channel publishes text + image immediately with GraphQL mode `shareNow`.
# Channel IDs are available from Buffer's `channels` GraphQL query/API explorer.
BUFFER_API_KEY=
BUFFER_LINKEDIN_CHANNEL_ID=
BUFFER_INSTAGRAM_CHANNEL_ID=
