# AkashiMedia — Фаза 1 MVP. Copy to .env and fill in. Never commit .env.

# --- Single shared login for the marketing team (Scope Cut: единый логин/пароль) ---
APP_USERNAME=marketing
APP_PASSWORD=change-me

# Session cookie signing key (>= 32 chars). Generate: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-me-to-a-long-random-hex-string

# Set to true when served behind TLS — adds the Secure flag to the session cookie.
APP_HTTPS_ONLY=false

# --- External APIs ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Instagram Graph API token (S2) — leave blank to run with the fake publisher
IG_TOKEN=
# Instagram Business account id (Graph API target)
IG_USER_ID=
# Public HTTPS base of this app — required for real Instagram photo posts.
# Graph fetches the image from <PUBLIC_BASE_URL>/media/<token>. In dev use a
# tunnel, e.g. `cloudflared tunnel --url http://localhost:8000`. Leave blank to
# keep Instagram media hosting disabled (publish reports "Phase 2").
PUBLIC_BASE_URL=

# LinkedIn API token (S3) — leave blank to run with the fake publisher
LI_TOKEN=
# LinkedIn member/author URN, e.g. urn:li:person:xxxx
LI_AUTHOR_URN=
